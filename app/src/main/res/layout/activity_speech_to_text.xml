<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FA"
    android:padding="20dp"
    tools:context=".SpeechToTextActivity">

    <!-- Header Section -->
    <TextView
        android:id="@+id/sttTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Live Translation"
        android:textColor="#1A1C1E"
        android:textSize="32sp"
        android:fontFamily="sans-serif-black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/indicatorDot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginStart="8dp"
        android:background="#4CAF50"
        app:layout_constraintBottom_toBottomOf="@id/sttTitle"
        app:layout_constraintStart_toEndOf="@id/sttTitle"
        app:layout_constraintTop_toTopOf="@id/sttTitle" />

    <TextView
        android:id="@+id/instructionText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Select languages and tap to listen."
        android:textColor="#6C757D"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toBottomOf="@id/sttTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Language Controls Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/instructionText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:baselineAligned="false">

            <!-- Source Language -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FROM (SPEAK)"
                    android:textSize="11sp"
                    android:textColor="#6C757D"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <androidx.appcompat.widget.AppCompatSpinner
                    android:id="@+id/sourceLanguageSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="4dp"
                    android:paddingStart="0dp"
                    android:theme="@style/ThemeOverlay.AppCompat.Light"
                    android:spinnerMode="dropdown"
                    android:popupBackground="#FFFFFF"/>
            </LinearLayout>

            <!-- Swap Arrow -->
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="8dp"
                android:src="@drawable/ic_arrow_forward"
                app:tint="#4CAF50"
                android:contentDescription="Translate to"/>

            <!-- Target Language -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TO (TRANSLATE)"
                    android:textSize="11sp"
                    android:textColor="#6C757D"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <androidx.appcompat.widget.AppCompatSpinner
                    android:id="@+id/targetLanguageSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="4dp"
                    android:paddingStart="0dp"
                    android:theme="@style/ThemeOverlay.AppCompat.Light"
                    android:spinnerMode="dropdown"
                    android:popupBackground="#FFFFFF"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Progress Section -->
    <LinearLayout
        android:id="@+id/progressLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardControls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:visibility="invisible"
            android:indeterminateTint="#1A1C1E"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Ready"
            android:textSize="14sp"
            android:textColor="#1A1C1E"
            android:visibility="invisible"/>
    </LinearLayout>

    <!-- Result Area -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardResult"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/progressLayout"
        app:layout_constraintBottom_toTopOf="@id/btnListen"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap 'Start Listening' below..."
                android:textSize="18sp"
                android:lineSpacingExtra="6dp"
                android:textColor="#1A1C1E"
                android:fontFamily="sans-serif"
                android:textIsSelectable="true" />
        </ScrollView>
    </androidx.cardview.widget.CardView>

    <!-- Action Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnListen"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:text="START LISTENING"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        app:cornerRadius="32dp"
        android:backgroundTint="#1A1C1E"
        app:rippleColor="#33FFFFFF"
        app:icon="@android:drawable/ic_btn_speak_now"
        app:iconGravity="textStart"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
